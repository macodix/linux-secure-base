# logrotate-Konfiguration fuer Linux Secure Base
#
# Zieldatei: /etc/logrotate.d/secure-base
# Installation: durch das logging-Modul oder das Deployment-Skript.
#
# copytruncate: Datei wird nach dem Kopieren auf 0 gekuerzt statt
# umbenannt — laufende tail-f-Prozesse verlieren den Dateihandle nicht.

/var/log/secure-base/secure-base.log {
    weekly
    size 5M
    compress
    rotate 8
    missingok
    notifempty
    copytruncate
}
