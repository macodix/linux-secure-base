#!/bin/bash
#
# Linux Secure Base — Installer
# Aufruf: secure-base-installer [OPTIONEN] <install|uninstall|check|test> [<modul> ...]
#
# Exit-Codes:
#   0 — Erfolg
#   1 — Fehler
#   2 — Aufruffehler (unbekanntes Subkommando, ungueltiges Argument)

set -euo pipefail

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
readonly SCRIPT_DIR

# shellcheck source=lib/common.sh
source "$SCRIPT_DIR/lib/common.sh"


# Kanonische Ausfuehrungs-Reihenfolge (nicht konfigurierbar).
readonly INSTALL_ORDER=(
    base postfix users ssh ufw fail2ban rkhunter
    logging unattended restic monit lynis
)

# Interaktive Module: fuer diese kein Lebenszeichen (Passwort-/Pubkey-Eingaben
# und Prompts liegen auf derselben Terminalzeile und wuerden gestoert).
readonly INTERACTIVE_MODULES=(users)

# Anzeige-Beschreibung je Modul fuer die Statusliste (Fallback: Modulname).
# In lib/ui.sh (ui_init) gelesen.
# shellcheck disable=SC2034  # cross-file in lib/ui.sh verwendet
declare -rA SB_MODUL_LABEL=(
    [base]="Grundkonfiguration"
    [postfix]="Mail-Versand"
    [users]="Hauptbenutzer"
    [ssh]="SSH-Härtung mit TOTP"
    [ufw]="Firewall"
    [fail2ban]="Brute-Force-Schutz"
    [rkhunter]="Schadsoftware-Schutz"
    [logging]="Protokollierung und Auditing"
    [unattended]="Automatische Sicherheitsupdates"
    [restic]="Datensicherung"
    [monit]="Monitoring"
    [lynis]="Härtungsprüfung"
    [report]="Abschluss-Dokumentation"
)

# Gemeinsamer Name des UI-Pseudo-Eintrags fuer die Abschluss-Doku.
# An mehreren Stellen verwendet (ui_init, Statuswechsel, ui_summary-Ausschluss).
readonly SB_REPORT_UI_NAME="report"

# Globale Zustandsvariablen (vom EXIT-Trap _sb_master_finish gelesen).
SB_DONE_COUNT=0
SB_CURRENT_MODUL=""
SB_TOTAL=0
# Liste der erfolgreich abgeschlossenen Module (fuer Abschluss-Doku).
declare -a SB_DONE_MODULES=()
# Fehlertext des abgebrochenen Moduls; in lib/ui.sh (ui_summary) gelesen.
SB_FAIL_TEXT=""
# Anzahl fehlgeschlagener Module bei check/test (kein Abbruch, Bilanz am Ende).
SB_FAIL_COUNT=0

# Optionen
OPT_QUIET=0
OPT_VERBOSE=0
OPT_DRYRUN=0

# -------------------------------------------------------------------------
# Hilfsfunktionen
# -------------------------------------------------------------------------

usage() {
    cat >&2 <<'EOF'
SYNOPSIS
    secure-base-installer [OPTIONEN] <KOMMANDO> [<modul> ...]

KOMMANDOS
    install    Module installieren und konfigurieren
    uninstall  Module-Konfiguration zuruecknehmen (umgekehrte Reihenfolge)
    check      Soll-Ist-Vergleich ohne Aenderungen
    test       Funktionstest ohne Aenderungen

OPTIONEN
    -c, --conf <pfad>  Alternative Konfigdatei (Default: conf/secure-base.conf)
    -q, --quiet        Nur WARN und ERROR ausgeben (kein INFO)
    -v, --verbose      INFO auch auf der Shell ausgeben (sonst nur im Logfile)
    -n, --dry-run      Trockenlauf: Statusliste sichtbar, keine Aenderungen
    -h, --help         Diese Hilfe ausgeben

EXIT STATUS
    0  Erfolg
    1  Fehler
    2  Aufruffehler

HINWEISE
    Ohne Modul-Argumente laufen alle in MODULES_ENABLED (secure-base.conf) aktivierten
    Module in der fest vorgegebenen Reihenfolge. Mit Modul-Argumenten nur die
    angegebenen (ebenfalls in der kanonischen Reihenfolge).

    Logdatei: /var/log/secure-base/secure-base.log (Append-Modus, alle Laeufe)
EOF
    exit 2
}

#######################################
# Prueft, ob $1 in den restlichen Argumenten enthalten ist.
# Arguments: $1 — Suchwert, $2+ — Liste
# Returns:   0 gefunden, 1 nicht gefunden
#######################################
in_list() {
    local needle=$1
    shift
    local item
    for item in "$@"; do
        [[ "$item" = "$needle" ]] && return 0
    done
    return 1
}

#######################################
# Validiert Modul-Argumente und gibt die Auswahl in INSTALL_ORDER-Reihenfolge
# auf stdout aus (ein Modul pro Zeile). Ohne Argumente: alle aktivierten Module.
# Globals:   INSTALL_ORDER, MODULES_ENABLED
# Arguments: $* — optionale Modulnamen
# Outputs:   stdout — ein Modulname pro Zeile
#######################################
select_modules() {
    local args=("$@")
    local m

    if [ "${#args[@]}" -eq 0 ]; then
        for m in "${INSTALL_ORDER[@]}"; do
            if in_list "$m" "${MODULES_ENABLED[@]}"; then
                printf '%s\n' "$m"
            fi
        done
        return 0
    fi

    local arg
    for arg in "${args[@]}"; do
        if ! in_list "$arg" "${INSTALL_ORDER[@]}"; then
            die "Unbekanntes Modul: $arg. Bekannte Module: ${INSTALL_ORDER[*]}"
        fi
        if ! in_list "$arg" "${MODULES_ENABLED[@]}"; then
            die "Modul $arg ist nicht in MODULES_ENABLED aktiviert (in secure-base.conf ergaenzen)"
        fi
    done

    for m in "${INSTALL_ORDER[@]}"; do
        if in_list "$m" "${args[@]}"; then
            printf '%s\n' "$m"
        fi
    done
}

#######################################
# Gibt die uebergebene Liste in umgekehrter Reihenfolge auf stdout aus.
# Arguments: $* — Liste
# Outputs:   stdout — ein Element pro Zeile
#######################################
reverse_array() {
    local i
    for ((i = $#; i >= 1; i--)); do
        printf '%s\n' "${!i}"
    done
}

#######################################
# Liest die letzte ERROR-Meldung des aktuellen Modul-Laufs aus dem
# zentralen Logfile. Eine einzige Quelle — kein separater Status-Mechanismus.
# Globals:   SB_CURRENT_LOG
# Arguments: $1 — Modulname, $2 — Subkommando
# Outputs:   stdout — Meldungstext, oder leer
#######################################
_letzte_fehlerzeile() {
    local modul=$1 sub=$2
    [ -f "${SB_CURRENT_LOG:-}" ] || return 0
    # Ab dem letzten Modul-Start-Marker (von dispatch geschrieben) die letzte
    # ERROR-Zeile lesen. So zaehlt nur der aktuelle Modul-Lauf; das zentrale
    # Logfile ist die einzige Quelle.
    local zeile
    zeile=$(grep -nF -- "--- Modul ${modul} (${sub}) ---" "${SB_CURRENT_LOG}" \
        | tail -1 | cut -d: -f1)
    [ -n "$zeile" ] || return 0
    tail -n "+${zeile}" "${SB_CURRENT_LOG}" 2>/dev/null \
        | grep ' ERROR ' | tail -1 | sed -E 's/^[^ ]+ +ERROR +//'
}

# -------------------------------------------------------------------------
# Interaktive ufw-Aktivierung nach erfolgreichem Install-Lauf
# -------------------------------------------------------------------------

#######################################
# Bietet nach einem erfolgreichen install-Lauf die interaktive Aktivierung
# der Firewall an. Laeuft nur, wenn ufw in SB_DONE_MODULES ist und ein
# echtes Terminal verfuegbar ist.
# Ohne interaktives Terminal: nur log INFO, keine Aktivierung.
# Default: NICHT aktivieren (nur explizites j/ja/y fuehrt zu ufw enable).
# Globals:   SB_DONE_MODULES (lesend)
# Arguments: keine
#######################################
_sb_offer_ufw_enable() {
    if ! in_list "ufw" "${SB_DONE_MODULES[@]}"; then
        return 0
    fi

    if ! [ -r /dev/tty ]; then
        log INFO "ufw: Firewall nicht aktiviert (kein interaktives Terminal) — manuell mit 'ufw enable' aktivieren."
        return 0
    fi

    {
        printf '\n'
        printf 'Die Firewall (ufw) ist konfiguriert, aber noch nicht aktiv.\n'
        printf 'Das Aktivieren kann die laufende SSH-Verbindung kurz unterbrechen\n'
        printf 'und die Anzeige aussetzen lassen — danach den Login in einer zweiten\n'
        printf 'Sitzung pruefen; bei Problemen: ufw disable\n'
        printf '\n'
        printf 'Firewall jetzt aktivieren? [j/N] '
    } >/dev/tty

    local antwort
    read -r antwort </dev/tty || antwort=""

    case "${antwort,,}" in
        j | ja | y | yes)
            ufw --force enable
            printf 'Firewall aktiviert — Login in einer zweiten Sitzung pruefen.\n' >/dev/tty
            log INFO "ufw: Firewall auf Anfrage aktiviert. Login in zweiter Sitzung pruefen."
            ;;
        *)
            printf 'Firewall nicht aktiviert — spaeter manuell mit: ufw enable\n' >/dev/tty
            log INFO "ufw: Firewall nicht aktiviert — manuell mit 'ufw enable' aktivieren."
            ;;
    esac
}

# -------------------------------------------------------------------------
# Abschluss-Sammelbilanz (EXIT-Trap)
# -------------------------------------------------------------------------

#######################################
# Abschluss-Sammelbilanz des Master-Laufs. Als EXIT-Trap gesetzt;
# feuert auch bei Fail-Fast-Abbruch eines Moduls.
# Globals:   SB_SUB, SB_TOTAL, SB_DONE_COUNT, SB_CURRENT_MODUL
#######################################
_sb_master_finish() {
    local rc=$?
    # Lebenszeichen-Poller beenden (idempotent), bevor Doku/Summary erscheinen.
    ui_heartbeat_stop
    # Abschluss-Doku: Erfolg -> Voll-Doku, Abbruch -> Teil-Doku mit Vermerk.
    # SB_REPORT_UI_NAME ist die gemeinsame readonly-Konstante des UI-Pseudo-
    # Eintrags (Plan 2.8); kein lokales Literal.
    if [ "$SB_SUB" = "install" ] && [ "${ENABLE_INSTALL_REPORT:-yes}" = "yes" ]; then
        if [ "${#SB_DONE_MODULES[@]}" -gt 0 ]; then
            ui_list_update "$SB_REPORT_UI_NAME" run
            if sb_install_report "$SB_SUB" "$rc" "$SB_CURRENT_MODUL" \
                "${SB_DONE_MODULES[@]}"; then
                ui_list_update "$SB_REPORT_UI_NAME" ok
            else
                ui_list_update "$SB_REPORT_UI_NAME" warn
            fi
        else
            ui_list_update "$SB_REPORT_UI_NAME" warn
        fi
    fi

    if [ "$rc" -eq 0 ]; then
        log INFO "=== Sammelbilanz ${SB_SUB}: alle ${SB_TOTAL} Module erfolgreich ==="
    elif { [ "$SB_SUB" = "check" ] || [ "$SB_SUB" = "test" ]; } && [ "$SB_FAIL_COUNT" -gt 0 ]; then
        log ERROR "=== Sammelbilanz ${SB_SUB}: ${SB_TOTAL}/${SB_TOTAL} Module geprüft, ${SB_FAIL_COUNT} mit Mängeln ==="
    else
        log ERROR "=== Sammelbilanz ${SB_SUB}: ${SB_DONE_COUNT}/${SB_TOTAL} Module erledigt, Abbruch bei ${SB_CURRENT_MODUL} ==="
    fi
    ui_summary
    if [ "$SB_SUB" = "install" ] && [ "$rc" -eq 0 ]; then
        _sb_offer_ufw_enable
    fi
    _sb_close_log
}

# -------------------------------------------------------------------------
# Argument-Parsing
# -------------------------------------------------------------------------

parse_args() {
    # Langoption-Umwandlung: --opt -> -o fuer getopts
    local args=()
    local a
    for a in "$@"; do
        case "$a" in
            --conf) args+=(-c) ;;
            --quiet) args+=(-q) ;;
            --verbose) args+=(-v) ;;
            --dry-run) args+=(-n) ;;
            --help) args+=(-h) ;;
            --) args+=("$a") ;;
            --*) printf 'Unbekannte Option: %s\n' "$a" >&2; exit 2 ;;
            *) args+=("$a") ;;
        esac
    done
    set -- "${args[@]}"

    local opt
    while getopts ':c:qvnh' opt; do
        case "$opt" in
            c) SB_CONF=$OPTARG ;;
            q) OPT_QUIET=1 ;;
            v) OPT_VERBOSE=1 ;;
            n) OPT_DRYRUN=1 ;;
            h) usage ;;
            :) printf 'Option -%s erwartet ein Argument\n' "$OPTARG" >&2; exit 2 ;;
            \?) printf 'Unbekannte Option: -%s\n' "$OPTARG" >&2; exit 2 ;;
        esac
    done
    shift $((OPTIND - 1))

    # Restargumente nach Optionen zurueck nach $@
    _PARSED_ARGS=("$@")
}

# -------------------------------------------------------------------------
# Hauptprogramm
# -------------------------------------------------------------------------

main() {
    # Argument-Parsing
    declare -a _PARSED_ARGS=()
    parse_args "$@"
    set -- "${_PARSED_ARGS[@]}"

    # Ausgabe-Steuerung aus den Optionen ableiten (vom Log-Filter und der UI
    # gelesen). Quiet hat Vorrang vor Verbose.
    if [ "$OPT_QUIET" -eq 1 ]; then
        SB_SHOW_INFO=0
        SB_QUIET=1
    elif [ "$OPT_VERBOSE" -eq 1 ]; then
        SB_SHOW_INFO=1
        SB_QUIET=0
    else
        SB_SHOW_INFO=0
        SB_QUIET=0
    fi
    export SB_SHOW_INFO SB_QUIET

    local sub=${1:-}
    if [ -z "$sub" ] || [ "$sub" = "-h" ] || [ "$sub" = "--help" ]; then
        usage
    fi
    shift

    case "$sub" in
        install | uninstall | check | test) ;;
        *)
            printf 'Unbekanntes Subkommando: %s\n' "$sub" >&2
            printf 'Erwartet: install | uninstall | check | test\n' >&2
            exit 2
            ;;
    esac

    # root nur fuer tatsaechlich aendernde Laeufe. check, test und jeder
    # Trockenlauf (-n) kommen ohne root aus.
    if { [ "$sub" = "install" ] || [ "$sub" = "uninstall" ]; } && [ "$OPT_DRYRUN" -eq 0 ]; then
        require_root
    fi
    load_conf "$SB_CONF"

    if ! [[ -v MODULES_ENABLED ]]; then
        die "MODULES_ENABLED nicht definiert in $SB_CONF"
    fi

    # Modul-Auswahl in separatem Schritt, damit die aus select_modules
    # gefeuerten die() nicht durch Process-Substitution maskiert werden.
    local ausgewaehlt_raw
    if ! ausgewaehlt_raw=$(select_modules "$@"); then
        exit 1
    fi
    local ausgewaehlt=()
    if [ -n "$ausgewaehlt_raw" ]; then
        mapfile -t ausgewaehlt <<<"$ausgewaehlt_raw"
    fi

    if [ "$sub" = "uninstall" ] && [ "${#ausgewaehlt[@]}" -gt 0 ]; then
        local reversed_raw
        if ! reversed_raw=$(reverse_array "${ausgewaehlt[@]}"); then
            exit 1
        fi
        mapfile -t ausgewaehlt <<<"$reversed_raw"
    fi

    if [ "${#ausgewaehlt[@]}" -eq 0 ]; then
        log INFO "Keine Module zu verarbeiten (MODULES_ENABLED leer oder Schnittmenge leer)"
        exit 0
    fi

    # Logdatei zuerst oeffnen: setzt SB_UI_TTY_FD (echtes Terminal-FD) und
    # SB_CURRENT_LOG (echter Logpfad) bevor die UI initialisiert wird.
    # So bekommt ui_init den richtigen FD und ui_banner den echten Pfad.
    open_log

    # Trennzeile je Lauf im Append-File, damit Laeufe unterscheidbar sind.
    local lauf_ts
    printf -v lauf_ts '%(%Y-%m-%d %H:%M:%S)T' -1
    log INFO "=== secure-base-installer · ${sub} · ${lauf_ts} ==="

    # UI-Liste = Module + Pseudo-Eintrag fuer die Abschluss-Doku (nur bei
    # install und aktiviertem Report). Der Eintrag ist KEIN Modul: er steht
    # nicht in "ausgewaehlt" und wird daher nie als Modul geladen/ausgefuehrt.
    local ui_eintraege=("${ausgewaehlt[@]}")
    if [ "$sub" = "install" ] && [ "${ENABLE_INSTALL_REPORT:-yes}" = "yes" ]; then
        ui_eintraege+=("$SB_REPORT_UI_NAME")
    fi
    ui_init "$SB_CURRENT_LOG" "${ui_eintraege[@]}"
    ui_banner "$sub" "$OPT_DRYRUN"

    log INFO "Sammel-Lauf gestartet: $sub (${#ausgewaehlt[@]} Modul(e): ${ausgewaehlt[*]})"

    SB_SUB=$sub
    SB_TOTAL=${#ausgewaehlt[@]}
    trap '_sb_master_finish' EXIT

    # Erste Darstellung der Statusliste
    ui_list_draw

    local total=${#ausgewaehlt[@]} idx=0
    local modul skript
    for modul in "${ausgewaehlt[@]}"; do
        idx=$((idx + 1))
        SB_CURRENT_MODUL=$modul

        ui_list_update "$modul" run

        # Lebenszeichen unter der Liste — nicht fuer interaktive Module.
        if ! in_list "$modul" "${INTERACTIVE_MODULES[@]}"; then
            ui_heartbeat_start "${SB_MODUL_LABEL[$modul]:-$modul}"
        fi

        skript="$SCRIPT_DIR/lib/modules/${modul}.sh"
        if [ ! -x "$skript" ]; then
            ui_heartbeat_stop
            log ERROR "Modul nicht installiert: ${modul}.sh fehlt unter $SCRIPT_DIR/lib/modules/"
            ui_list_update "$modul" error "nicht installiert"
            # shellcheck disable=SC2034  # in lib/ui.sh (ui_summary) gelesen
            SB_FAIL_TEXT="Modul ${modul} nicht installiert (${modul}.sh fehlt)"
            exit 1
        fi

        log INFO "[$idx/$total] Starte Modul: $modul ($sub)"

        local modul_rc=0
        if [ "$OPT_DRYRUN" -eq 1 ]; then
            log INFO "[$idx/$total] Trockenlauf — $modul wird uebersprungen"
            sleep 0.3  # kurze Pause fuer sichtbaren Live-Effekt
        else
            "$skript" "$sub" || modul_rc=$?
        fi

        # Lebenszeichen stoppen, bevor der naechste Zustandswechsel gezeichnet wird.
        ui_heartbeat_stop

        if [ "$modul_rc" -eq 0 ]; then
            log INFO "[$idx/$total] Modul abgeschlossen: $modul ($sub)"
            ui_list_update "$modul" ok
            SB_DONE_COUNT=$((SB_DONE_COUNT + 1))
            SB_DONE_MODULES+=("$modul")
        elif [ "$sub" = "check" ] || [ "$sub" = "test" ]; then
            # check/test: nicht abbrechen, alle Module durchlaufen und bilanzieren.
            log ERROR "[$idx/$total] Modul meldet Maengel: $modul ($sub) — Exit $modul_rc"
            ui_list_update "$modul" error "Maengel gefunden (Exit $modul_rc)"
            SB_FAIL_COUNT=$((SB_FAIL_COUNT + 1))
        else
            # install/uninstall: Fail-Fast wie bisher.
            # Fehlermeldung des Moduls ab dessen Start-Marker aus dem Logfile,
            # BEVOR der Installer seine eigene ERROR-Zeile schreibt.
            # shellcheck disable=SC2034  # in lib/ui.sh (ui_summary) gelesen
            SB_FAIL_TEXT=$(_letzte_fehlerzeile "$modul" "$sub")
            log ERROR "[$idx/$total] Modul fehlgeschlagen: $modul ($sub) — Exit $modul_rc"
            ui_list_update "$modul" error "fehlgeschlagen (Exit $modul_rc)"
            exit 1
        fi
    done
    # Bei check/test mit Mängeln: Exit 1, damit _sb_master_finish rc=1 sieht
    # und die Bilanz korrekt ausgibt. Bei install/uninstall bleibt der Schleifenende
    # (rc=0) korrekt; Fehler dort verlassen die Schleife per exit 1 oben.
    if { [ "$sub" = "check" ] || [ "$sub" = "test" ]; } && [ "$SB_FAIL_COUNT" -gt 0 ]; then
        exit 1
    fi
    # Abschluss-Sammelbilanz uebernimmt _sb_master_finish (EXIT-Trap).
}

main "$@"
