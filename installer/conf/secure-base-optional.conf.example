# secure-base-optional.conf.example — Vorlage fuer conf/secure-base-optional.conf
# (Zwei-Datei-Muster, konv-dateien-verzeichnisse.md Abschnitt 3.1).
#
# Diese Datei steuert die OPTIONALEN Pakete des Installers. Sie ist getrennt
# von secure-base.conf: optionale Pakete werden NICHT ueber MODULES_ENABLED
# aktiviert, sondern hier — und nur mit dem Schalter -o verarbeitet:
#
#     secure-base-installer -o install
#
# Auf dem Zielsystem nach conf/secure-base-optional.conf kopieren und die
# benoetigten Eintraege freischalten (Kommentarzeichen entfernen). Die echte
# .conf wird nie ins Repository eingecheckt.
#
# Ohne Freischaltung ist kein optionales Paket aktiv.

# == Aktivierung ==

# Liste der aktiven optionalen Pakete. Nur hier aufgefuehrte Pakete werden
# mit -o verarbeitet. Bekannte Pakete: nginx
# Beispiel (nginx aktivieren):
# OPTIONAL_ENABLED=(nginx)
OPTIONAL_ENABLED=()

# == nginx ==

# Administrative E-Mail fuer die Zertifikatsregistrierung bei Let's Encrypt
# (certbot). Pflicht, sobald nginx aktiviert ist. Faellt auf ADMIN_MAIL aus
# secure-base.conf zurueck, wenn hier leer.
# NGINX_CERTBOT_MAIL=""

# vhost-Definitionen. Je Zeile ein virtueller Host im Format:
#     "domain|docroot"
# docroot ist optional; ohne Angabe wird /var/www/<domain> verwendet. Mehrere
# Eintraege sind moeglich (zwei bis vier Domains erwartet). Mindestens ein
# Eintrag ist Pflicht, sobald nginx aktiviert ist.
#
# Beispiel mit zwei Domains, einer davon mit eigenem docroot:
# NGINX_VHOSTS=(
#     "example.com"
#     "shop.example.com|/srv/www/shop"
# )

# certbot-Betriebsmodus:
#   staging  — Testzertifikate (Let's-Encrypt-Staging, kein Rate-Limit-Risiko).
#              Fuer den ersten Probelauf empfohlen.
#   live (Default bei leerem Wert) — echte, vertrauenswuerdige Zertifikate.
# NGINX_CERTBOT_MODE="live"
