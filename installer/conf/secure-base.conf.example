# secure-base.conf.example — Vorlage fuer conf/secure-base.conf (Zwei-Datei-Muster).
#
# Auf dem Zielsystem nach conf/secure-base.conf kopieren und die Platzhalter
# durch die echten Werte ersetzen. Die echte secure-base.conf wird nie ins
# Repository eingecheckt. Alle Modul-Einstellungen stehen in dieser einen
# Datei, gegliedert nach Abschnitten.
#
# Herkunft des Zwei-Datei-Musters: konv-dateien-verzeichnisse.md Abschnitt 3.1.

# == Allgemein ==

# Aktivierung der Module. Die Ausfuehrungs-Reihenfolge ist fest vorgegeben;
# diese Liste legt nur fest, welche Module mitlaufen. Nicht benoetigte
# Module auskommentieren oder entfernen.
MODULES_ENABLED=(base postfix users ssh ufw fail2ban rkhunter \
    logging unattended restic monit lynis)

# Vollstaendiger FQDN des Servers (z. B. "srv001.example.com").
FQDN=""

# Administrative E-Mail-Adresse fuer alle Benachrichtigungen
# (Logwatch, fail2ban, rkhunter, unattended-upgrades, restic, monit, SSH-Login).
ADMIN_MAIL=""

# == base ==

# Zeitzone fuer das System (tzdata-Schreibweise).
TIMEZONE="Europe/Berlin"

# == ssh ==

# Schaltet die Login-Mail-Benachrichtigung an oder aus.
#   yes (Default bei leerem Wert) — /etc/ssh/login-mail-notification.sh
#       und eine pam_exec-session-Zeile in /etc/pam.d/sshd werden angelegt;
#       bei jedem SSH-Login geht eine Mail an ADMIN_MAIL.
#   no  — die beiden Dateien werden nicht angelegt; ein eventueller Bestand
#       wird durch uninstall entfernt, nicht durch install uebergangen.
ENABLE_LOGIN_MAIL="yes"

# Setzt den deprecated-Alias ChallengeResponseAuthentication in sshd_config.
# Seit OpenSSH 8.7 nur noch Alias zu KbdInteractiveAuthentication.
# Per Default gesetzt (yes) fuer Kompatibilitaet mit aelteren OpenSSH-Versionen;
# auf aktuellen Systemen (OpenSSH >= 9.x) redundant, aber unschaedlich.
#   yes (Default) — ChallengeResponseAuthentication yes wird gesetzt.
#   no            — Direktive wird nicht gesetzt und, falls vorhanden, entfernt.
ENABLE_CHALLENGE_RESPONSE_AUTH="yes"

# == postfix ==

# SMTP-Smarthost (Relay), an den Postfix als Satellite ausliefert.
RELAY_HOST=""

# Port des Smarthosts (Submission/STARTTLS ueblich 587).
RELAY_PORT="587"

# Benutzername fuer die SMTP-Authentifizierung am Smarthost.
RELAY_USER=""

# Passwort fuer die SMTP-Authentifizierung. Leer lassen, dann fragt das
# install interaktiv danach (kein Echo, nichts im Logfile).
RELAY_PASSWORD=""

# == users ==

# Hauptbenutzer-Login fuer den nicht-root-Account auf dem System
# (wird vom users-Modul angelegt; das ssh-Modul prueft ihn beim Haerten).
MAIN_USER=""

# Login-Passwort des Hauptbenutzers (Klartext).
# Leer lassen fuer interaktive Eingabe waehrend install (read -s, kein
# Echo; landet nur in chpasswd-stdin, nicht in diese Datei zurueck).
MAIN_USER_PASSWORD=""

# SSH-Public-Key des Hauptbenutzers (Inhalt einer .pub-Datei).
# Bevorzugt vor MAIN_USER_PUBKEY_FILE, wenn nicht leer.
# Beispiel: ssh-ed25519 AAAA... user@laptop
MAIN_USER_PUBKEY=""

# Alternativ: Pfad zu einer .pub-Datei, falls MAIN_USER_PUBKEY leer ist.
# Wird gelesen, dann verworfen — der Pfad wandert nicht in die
# authorized_keys.
MAIN_USER_PUBKEY_FILE=""

# Force-Schalter fuer uninstall:
#   no  (Default) — nur Gruppe ssh-users und Mitgliedschaft zurueck;
#                   Hauptbenutzer, Home, Passwoerter, TOTP, Pubkey
#                   bleiben unveraendert.
#   yes           — zusaetzlich userdel -r "$MAIN_USER" — Benutzer mit
#                   Home-Verzeichnis entfernen; TOTP und Pubkey gehen
#                   verloren.
UNINSTALL_REMOVE_USER="no"

# Zustellung des TOTP-Secrets bei der Einrichtung:
#   terminal (Default) — QR-Code, Secret und Notfall-Codes erscheinen am
#                        Bildschirm; das install pausiert zum Scannen.
#   mail               — QR-Bild (Anhang) und Secret gehen an ADMIN_MAIL,
#                        das install laeuft ohne Pause durch (unattended).
#                        SICHERHEITSHINWEIS: Der QR-Code enthaelt das Secret;
#                        per Mail liegt der zweite Faktor im Postfach und ist
#                        nur transportverschluesselt. Mail nach der
#                        Einrichtung sofort loeschen. Benoetigt ADMIN_MAIL
#                        und ein funktionsfaehiges Mail-Relay (postfix-Modul).
TOTP_DELIVERY="terminal"

# == ufw ==

# Eingehend erlaubte TCP-Ports. MUSS 22 (SSH) enthalten, sonst sperrt
# die Firewall den Verwaltungszugang aus (das install-Skript bricht
# ohne 22 mit Fehler ab).
ALLOW_IN_TCP=(22)

# Ausgehend erlaubte TCP-Ports:
#   587 — Submission/STARTTLS (Postfix-Relay; muss zu RELAY_PORT passen)
#    80 — HTTP  (apt, ACME)
#   443 — HTTPS (apt, Git, API-Calls)
#    53 — DNS (TCP)
#    22 — SSH  (Git-Push, restic-SFTP-Backup)
ALLOW_OUT_TCP=(587 80 443 53 22)

# Ausgehend erlaubte UDP-Ports:
#    53 — DNS (UDP)
ALLOW_OUT_UDP=(53)

# == fail2ban ==

# Optionale IP-/CIDR-Whitelist (leerzeichengetrennt), die fail2ban nie
# bannt. Hier die eigene Admin-/Management-IP eintragen, um sich nicht
# nach wiederholten Fehl-Logins selbst auszusperren. Die Loopback-
# Adressen (127.0.0.1/8 ::1) bleiben immer erhalten und muessen hier
# NICHT wiederholt werden. Leer = keine zusaetzliche Whitelist.
# Beispiel: IGNOREIP="203.0.113.7 198.51.100.0/24"
IGNOREIP=""

# == logging ==

# Maximaler Plattenverbrauch des persistenten Journals (journald
# SystemMaxUse). Leer = 1G (Doku-Default). Beispiel: "2G", "500M".
JOURNALD_MAX_USE=""

# Aufbewahrungsfrist des persistenten Journals (journald
# MaxRetentionSec). Leer = 3month (Doku-Default). Beispiel: "6month",
# "4week".
JOURNALD_MAX_RETENTION=""

# == unattended ==

# Automatischer Reboot nach Updates, die einen Neustart verlangen
# (z. B. Kernel). "true" oder "false". Leer = true (Doku-Default).
AUTO_REBOOT="true"

# Uhrzeit des automatischen Reboots (HH:MM). Leer = 23:45 (Doku-Default).
AUTO_REBOOT_TIME="23:45"

# Uhrzeit der taeglichen Paketlisten-Aktualisierung (apt-daily.timer,
# HH:MM). Leer = 23:15 (Doku-Default).
APT_DAILY_TIME="23:15"

# Uhrzeit des taeglichen Upgrade-Laufs (apt-daily-upgrade.timer, HH:MM).
# Sollte zwischen APT_DAILY_TIME und AUTO_REBOOT_TIME liegen, damit
# Updates vor dem Reboot installiert sind. Leer = 23:30 (Doku-Default).
APT_DAILY_UPGRADE_TIME="23:30"

# == restic ==

# Host-Alias aus /root/.ssh/config (muss dort bereits konfiguriert sein).
# Geht in die Repo-URL (sftp:<alias>:<pfad>) und die ssh-Aufrufe.
SFTP_HOST_ALIAS=""

# Zielpfad des Repos auf dem SFTP-Server. install legt ihn bei Bedarf an
# (mkdir -p, idempotent - ein vorhandenes Verzeichnis ist unkritisch).
# Der Elternpfad muss fuer den SFTP-Benutzer beschreibbar sein.
SFTP_PATH=""

# Passphrase zur Verschluesselung des Backup-Repos (NICHT der SSH-Key).
# Leer lassen, um beim Lauf einmalig per Eingabe (ohne Echo) zu setzen
# bzw. eine bereits vorhandene /root/config/restic-passphrase zu behalten.
RESTIC_PASSPHRASE=""

# == monit ==

# Absender-Adresse der monit-Alarm-Mails (Feld "from:" im mail-format).
MONIT_MAIL_FROM="monit@example.com"

# Welche Checks unter /etc/monit/conf.d/ angelegt werden.
# Erlaubte Werte: system rootfs sshd postfix fail2ban ufw cron rkhunter restic
# Default: alle neun.
CHECKS_ENABLED=(system rootfs sshd postfix fail2ban ufw cron rkhunter restic)

# == lynis ==

# Cron-Zeitplan der Haertungspruefung (5 Cron-Felder:
# Minute Stunde Tag Monat Wochentag). Leer = "0 4 1 * *" (monatlich am 1.
# um 04:00). Beispiel woechentlich Sonntag 03:30: "30 3 * * 0".
LYNIS_SCHEDULE="0 4 1 * *"
