# Zentrale ShellCheck-Konfiguration fuer linux-secure-base
# (konv-scripting-bash.md Kap. 3a/3c: nur zwingende, begruendete Einstellungen,
#  keine Lockerung von Checks).
#
# external-sources erlaubt ShellCheck, den `# shellcheck source=`-Direktiven
# in den Skripten zu folgen. Die Module sourcen lib/common.sh ueber einen
# relativen Pfad ($SCRIPT_DIR ist zur Analysezeit unbekannt); mit
# external-sources wird die Quelle aufgeloest statt als SC1091 gemeldet.
external-sources=true

# source-path=SCRIPTDIR loest die `source=`-Pfade relativ zum jeweiligen
# Skript-Verzeichnis auf (statt relativ zum Aufruf-Verzeichnis), damit
# ../../lib/common.sh aus den Modulen gefunden wird.
source-path=SCRIPTDIR
